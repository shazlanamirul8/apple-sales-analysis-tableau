            <column caption='Above Avg Profit' datatype='boolean' name='[Calculation_0970641771397120]' role='measure' type='nominal'>
              <calculation class='tableau' formula='SUM([discounted_price_usd])&gt;=WINDOW_AVG(SUM([discounted_price_usd]))'>
